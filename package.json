{
  "name": "urc-website-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-notice.cjs && npx --yes kill-port@latest 3000 3001 3010 3020 && next dev --webpack",
    "dev:restart": "npm run dev",
    "dev:turbo": "next dev",
    "build": "next build",
    "start": "npx --yes serve@latest out -l 3000",
    "lint": "eslint",
    "preview:cf": "npm run build && wrangler pages dev out",
    "deploy:cf": "npm run build && npx wrangler pages deploy out --project-name=urc-website-v2 --commit-dirty=true"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "next": "16.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
